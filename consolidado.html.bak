<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Consolidado — Meio Comunica</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f5; color: #111; }
        .header { background: #111; color: white; padding: 24px 40px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
        .header-left { display: flex; align-items: center; gap: 14px; }
        .logo-mark { width: 38px; height: 38px; background: #F5C800; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 17px; color: #111; flex-shrink: 0; }
        .header h1 { font-size: 18px; font-weight: 700; color: #fff; letter-spacing: -0.2px; }
        .header .meta { font-size: 12px; color: #888; margin-top: 3px; }
        .header .updated { font-size: 12px; color: #888; text-align: right; }
        .container { max-width: 1300px; margin: 0 auto; padding: 24px 32px; }
        .kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 22px; }
        .kpi { background: white; border-radius: 12px; padding: 18px 20px; box-shadow: 0 1px 3px rgba(0,0,0,.07); border-left: 4px solid #F5C800; }
        .kpi.hl { background: #111; border-left-color: #F5C800; }
        .kpi .lbl { font-size: 10px; text-transform: uppercase; letter-spacing: .6px; color: #999; margin-bottom: 6px; font-weight: 700; }
        .kpi.hl .lbl { color: #666; }
        .kpi .val { font-size: 26px; font-weight: 800; color: #111; }
        .kpi.hl .val { color: #F5C800; }
        .kpi .sub { font-size: 11px; color: #888; margin-top: 4px; }
        .kpi.hl .sub { color: #555; }
        .grid2 { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; margin-bottom: 20px; }
        .grid3 { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 16px; margin-bottom: 20px; }
        .section { background: white; border-radius: 12px; padding: 20px 22px; box-shadow: 0 1px 3px rgba(0,0,0,.07); }
        .st { font-size: 12px; font-weight: 800; color: #111; text-transform: uppercase; letter-spacing: .5px; border-bottom: 2px solid #F5C800; padding-bottom: 8px; margin-bottom: 14px; }
        table { width: 100%; border-collapse: collapse; font-size: 13px; }
        th { text-align: left; padding: 9px 10px; background: #fafafa; color: #aaa; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; }
        th .sub { font-weight: 400; font-size: 9px; color: #bbb; text-transform: none; letter-spacing: 0; display: block; margin-top: 2px; }
        td { padding: 10px 10px; border-top: 1px solid #f0f0f0; vertical-align: middle; color: #333; }
        tr:hover td { background: #fafaf8; }
        .footer { text-align: center; color: #bbb; font-size: 11px; padding: 20px; }
        #modal-overlay { display: none; position: fixed; inset: 0; background: rgba(15,23,42,.55); backdrop-filter: blur(2px); z-index: 1000; align-items: center; justify-content: center; }
        #modal-overlay.open { display: flex; }
        #modal-box { background: white; border-radius: 16px; padding: 28px 32px; max-width: 520px; width: 90%; max-height: 80vh; overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,.25); }
        #modal-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 18px; }
        #modal-title { font-size: 16px; font-weight: 700; color: #0f172a; }
        #modal-subtitle { font-size: 12px; color: #9ca3af; margin-top: 3px; }
        #modal-close { background: #f1f5f9; border: none; border-radius: 8px; width: 32px; height: 32px; font-size: 16px; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: #64748b; }
        #modal-close:hover { background: #e2e8f0; }
    </style>
</head>
<body>

<div id="modal-overlay" onclick="if(event.target===this)closeModal()">
    <div id="modal-box">
        <div id="modal-header">
            <div><div id="modal-title">Alertas</div><div id="modal-subtitle"></div></div>
            <button id="modal-close" onclick="closeModal()">✕</button>
        </div>
        <div id="modal-body"></div>
    </div>
</div>

<script>
const ALERTS = {
    "IOA Campinas - Alunos": [],
    "IOA Campinas - Pacientes": [],
    "IOA Ribeirao Preto": [
        {"type": "warning", "msg": "🟡 Frequência alta: campanha ENDODONTIA — freq 3,0 — monitorar fadiga"},
        {"type": "warning", "msg": "🟡 Frequência alta: campanha DENTÍSTICA — freq 3,2 — monitorar fadiga"}
    ],
    "Faculdade IOA": [
        {"type": "critical", "msg": "🔴 Sem leads: \"Post do Instagram: A mesma graduação pod\" — R$138 investidos"},
        {"type": "critical", "msg": "🔴 Sem leads: \"Post do Instagram: Quando a experiência \" — R$104 investidos"}
    ],
    "IOA Piracicaba": [
        {"type": "warning", "msg": "⚠️ Criativo fatigado: \"engajamento_cursos_08.04.26\" — freq 3,5 — planejar substituição"}
    ],
    "Mikro Metais": [],
    "Endotec": [],
    "Baby Center": []
};
function showAlerts(client) {
    const alerts = ALERTS[client] || [];
    document.getElementById('modal-title').textContent = client;
    document.getElementById('modal-subtitle').textContent = alerts.length + ' alerta(s)';
    const body = document.getElementById('modal-body');
    if (!alerts.length) { body.innerHTML = '<div style="color:#10b981;font-size:14px;padding:12px 0">✅ Nenhum alerta</div>'; }
    else {
        const s = { critical: [], warning: [] };
        alerts.forEach(a => s[a.type].push(a));
        let h = '';
        if (s.critical.length) {
            h += '<div style="font-size:10px;font-weight:700;color:#ef4444;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px">🔴 Ação Imediata</div>';
            s.critical.forEach(a => { h += `<div style="padding:10px 14px;margin:5px 0;border-radius:8px;background:#fef2f2;border-left:3px solid #ef4444;font-size:13px;line-height:1.5">${a.msg}</div>`; });
        }
        if (s.warning.length) {
            h += '<div style="font-size:10px;font-weight:700;color:#d97706;text-transform:uppercase;letter-spacing:.5px;margin:14px 0 8px">🟡 Monitorar</div>';
            s.warning.forEach(a => { h += `<div style="padding:10px 14px;margin:5px 0;border-radius:8px;background:#fffbeb;border-left:3px solid #f59e0b;font-size:13px;line-height:1.5">${a.msg}</div>`; });
        }
        body.innerHTML = h;
    }
    document.getElementById('modal-overlay').classList.add('open');
}
function showAllAlerts() {
    const all = [];
    Object.entries(ALERTS).forEach(([client, alerts]) => {
        alerts.filter(a => a.type === 'critical').forEach(a => { all.push({ client, msg: a.msg }); });
    });
    document.getElementById('modal-title').textContent = '🔴 Todos os alertas críticos';
    document.getElementById('modal-subtitle').textContent = all.length + ' alerta(s) que exigem ação imediata';
    const body = document.getElementById('modal-body');
    if (!all.length) {
        body.innerHTML = '<div style="color:#10b981;font-size:14px;padding:12px 0">✅ Nenhum alerta crítico</div>';
    } else {
        let lastClient = '';
        let h = '';
        all.forEach(a => {
            if (a.client !== lastClient) {
                h += `<div style="font-size:10px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin:${lastClient ? '16px' : '0'} 0 6px">${a.client}</div>`;
                lastClient = a.client;
            }
            h += `<div style="padding:9px 13px;margin:4px 0;border-radius:8px;background:#fef2f2;border-left:3px solid #ef4444;font-size:13px;line-height:1.5">${a.msg}</div>`;
        });
        body.innerHTML = h;
    }
    document.getElementById('modal-overlay').classList.add('open');
}
function closeModal() { document.getElementById('modal-overlay').classList.remove('open'); }
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>

